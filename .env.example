# Copy to `.env.local` and fill in real values. Never commit `.env.local`.

# --- OpenAI (required for /api/insights and /api/chat) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- News provider 1 (e.g. NewsData.io latest endpoint) ---
NEWS1_API_URL=https://newsdata.io/api/1/latest
NEWS1_API_KEY=
# NEWS1_API_KEY_PARAM=apikey
# NEWS1_REQUEST_PARAMS=

# --- News provider 2 (e.g. NewsAPI.org everything) ---
NEWS2_API_URL=https://newsapi.org/v2/everything
NEWS2_API_KEY=
# NEWS2_API_KEY_PARAM=apiKey
# NEWS2_REQUEST_PARAMS=

# --- Optional tuning ---
# NEWS_PROVIDER_TIMEOUT_MS=15000
# INSIGHTS_CACHE_SECONDS=90
