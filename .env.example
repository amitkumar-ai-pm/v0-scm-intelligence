# Copy to `.env.local` and fill in real values. Never commit `.env.local`.

# --- OpenAI (required for /api/insights and /api/chat) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- News provider 1 (e.g. NewsData.io latest endpoint) ---
NEWS1_API_URL=https://newsdata.io/api/1/latest
NEWS1_API_KEY=
# NEWS1_API_KEY_PARAM=apikey
# NEWS1_REQUEST_PARAMS=

# --- News provider 2 (e.g. NewsAPI.org everything) ---
NEWS2_API_URL=https://newsapi.org/v2/everything
NEWS2_API_KEY=
# NEWS2_API_KEY_PARAM=apiKey
# NEWS2_REQUEST_PARAMS=

# --- Optional tuning ---
# NEWS_PROVIDER_TIMEOUT_MS=15000
# INSIGHTS_CACHE_SECONDS=90

# --- Access gate (Path 2: private deploy; required in production) ---
# Generate: openssl rand -base64 32   (or any 32+ char secret)
AUTH_SECRET=
# Single shared password for trusted users (store only in env / Vercel)
SITE_ACCESS_PASSWORD=
# Upstash Redis REST (https://console.upstash.com) — global + login rate limits
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local dev only: skip login gate (NEVER set to true in Vercel production)
# SKIP_AUTH=true
